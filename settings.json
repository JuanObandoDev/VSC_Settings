{
  "terminal.integrated.defaultProfile.windows": "Git Bash",
  "terminal.integrated.defaultProfile.osx": "zsh",
  "terminal.integrated.defaultProfile.linux": "bash",

  "workbench.sideBar.location": "right",
  "workbench.editor.showTabs": "none",
  "editor.minimap.enabled": false,
  "editor.scrollbar.vertical": "hidden",
  "editor.overviewRulerBorder": false,
  "editor.hideCursorInOverviewRuler": true,
  "editor.formatOnSave": true,
  "editor.guides.indentation": false,
  "indenticator.width": 0.5,
  "indenticator.color.dark": "rgba(255,255,255,0.1)",
  "editor.matchBrackets": "never",
  "editor.glyphMargin": false,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.formatOnType": true,
  "editor.cursorBlinking": "expand",
  "editor.linkedEditing": true,
  "editor.bracketPairColorization.enabled": true,
  "editor.stickyScroll.enabled": true,
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.smoothScrolling": true,
  "chat.instructionsFilesLocations": {
    ".github/instructions": true,
    ".claude/rules": true,
    "~/.copilot/instructions": true,
    "~/.claude/rules": true,

    // Windows (AppData)
    "~/AppData/Local/Temp/postman-collections-post-response.instructions.md": true,
    "~/AppData/Local/Temp/postman-collections-pre-request.instructions.md": true,
    "~/AppData/Local/Temp/postman-folder-post-response.instructions.md": true,
    "~/AppData/Local/Temp/postman-folder-pre-request.instructions.md": true,
    "~/AppData/Local/Temp/postman-http-request-post-response.instructions.md": true,
    "~/AppData/Local/Temp/postman-http-request-pre-request.instructions.md": true,

    // macOS (tmp)
    "~/tmp/postman-collections-post-response.instructions.md": true,
    "~/tmp/postman-collections-pre-request.instructions.md": true,
    "~/tmp/postman-folder-post-response.instructions.md": true,
    "~/tmp/postman-folder-pre-request.instructions.md": true,
    "~/tmp/postman-http-request-post-response.instructions.md": true,
    "~/tmp/postman-http-request-pre-request.instructions.md": true,
  },
}
